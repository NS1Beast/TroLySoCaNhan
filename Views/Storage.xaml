<ui:FluentWindow x:Class="TroLySoCaNhan.Views.Storage"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 mc:Ignorable="d"
                 Title="Kho lưu trữ tài liệu"
                 Height="820"
                 Width="1320"
                 MinHeight="760"
                 MinWidth="1180"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True"
                 WindowStartupLocation="CenterScreen"
                 TextOptions.TextFormattingMode="Display"
                 TextOptions.TextRenderingMode="ClearType">

    <ui:FluentWindow.Resources>

        <!-- =========================
             MÀU CHỦ ĐẠO
        ========================== -->
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#0F172A"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#64748B"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#94A3B8"/>

        <SolidColorBrush x:Key="BluePrimaryBrush" Color="#2563EB"/>
        <SolidColorBrush x:Key="BlueDarkBrush" Color="#1D4ED8"/>
        <SolidColorBrush x:Key="BlueSoftBrush" Color="#EFF6FF"/>
        <SolidColorBrush x:Key="BlueBorderBrush" Color="#CFE3FF"/>

        <SolidColorBrush x:Key="SurfaceBrush" Color="#EEFFFFFF"/>
        <SolidColorBrush x:Key="InputBackgroundBrush" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="InputBorderBrush" Color="#D8E6FF"/>

        <!-- =========================
             TEXT STYLE
        ========================== -->
        <Style x:Key="PageTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="PageSubTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="LineHeight" Value="21"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="SmallMutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- =========================
             CARD STYLE
        ========================== -->
        <Style x:Key="GlassCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="26"/>
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BlueBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="22"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="34"
                                      ShadowDepth="10"
                                      Opacity="0.13"
                                      Color="#2563EB"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MiniCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="22"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#D8E6FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="22"
                                      ShadowDepth="6"
                                      Opacity="0.08"
                                      Color="#2563EB"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundedSearchBorderStyle" TargetType="Border">
            <Setter Property="Height" Value="46"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- =========================
             INPUT STYLE
        ========================== -->
        <Style x:Key="SearchTextBoxStyle" TargetType="{x:Type ui:TextBox}">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="12,0,12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- =========================
             BUTTON STYLE
        ========================== -->
        <Style x:Key="PrimaryActionButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="46"/>
            <Setter Property="MinWidth" Value="128"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="BorderBrush" Value="#2563EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1D4ED8"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#1D4ED8"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1E40AF"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryActionButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="46"/>
            <Setter Property="MinWidth" Value="104"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#D8E6FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#EFF6FF"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#BFDBFE"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#DBEAFE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MiniIconButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#D8E6FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#EFF6FF"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#BFDBFE"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#DBEAFE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- =========================
             DATAGRID STYLE
        ========================== -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="#FFFFFF"/>
            <Setter Property="AlternatingRowBackground" Value="#F8FAFC"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E2E8F0"/>
            <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#EFF6FF"/>
            <Setter Property="Foreground" Value="#1E3A8A"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="BorderBrush" Value="#D8E6FF"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Height" Value="46"/>
        </Style>

    </ui:FluentWindow.Resources>

    <Grid>

        <!-- =========================
             NỀN GRADIENT
        ========================== -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FFFFFF" Offset="0.00"/>
                <GradientStop Color="#F3F9FF" Offset="0.34"/>
                <GradientStop Color="#DBEAFE" Offset="0.78"/>
                <GradientStop Color="#EFF6FF" Offset="1.00"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Ellipse Width="480"
                 Height="480"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"
                 Margin="-190,-190,0,0"
                 Opacity="0.48">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#60A5FA" Offset="0"/>
                    <GradientStop Color="#BFDBFE" Offset="0.55"/>
                    <GradientStop Color="#00FFFFFF" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
            <Ellipse.Effect>
                <BlurEffect Radius="42"/>
            </Ellipse.Effect>
        </Ellipse>

        <Ellipse Width="560"
                 Height="560"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Bottom"
                 Margin="0,0,-230,-250"
                 Opacity="0.42">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#93C5FD" Offset="0"/>
                    <GradientStop Color="#DBEAFE" Offset="0.55"/>
                    <GradientStop Color="#00FFFFFF" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
            <Ellipse.Effect>
                <BlurEffect Radius="48"/>
            </Ellipse.Effect>
        </Ellipse>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- =========================
                 TITLE BAR
            ========================== -->
            <ui:TitleBar Grid.Row="0"
                         Title="Kho lưu trữ tài liệu"
                         Foreground="#0F172A"
                         Background="Transparent">
                <ui:TitleBar.Icon>
                    <ui:SymbolIcon Symbol="ArrowUpload24" Foreground="#2563EB"/>
                </ui:TitleBar.Icon>
            </ui:TitleBar>

            <!-- =========================
                 CONTENT
            ========================== -->
            <Grid Grid.Row="1" Margin="28,20,28,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- HEADER -->
                <Grid Grid.Row="0" Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Kho lưu trữ tài liệu"
                                   Style="{StaticResource PageTitleStyle}"/>

                        <TextBlock Text="Quản lý tài liệu cá nhân, nhóm lưu trữ, phiên bản file, OCR, AI và đồng bộ Cloudflare R2 trong một màn hình."
                                   Style="{StaticResource PageSubTitleStyle}"
                                   Margin="0,6,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">

                        <Button x:Name="BtnRefresh"
                                Style="{StaticResource SecondaryActionButtonStyle}"
                                Margin="0,0,10,0">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Search24"
                                               Foreground="#2563EB"
                                               FontSize="18"
                                               Margin="0,0,7,0"/>
                                <TextBlock Text="Làm mới"
                                           Foreground="#0F172A"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="BtnUploadCloud"
                                Style="{StaticResource PrimaryActionButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="ArrowUpload24"
                                               Foreground="#FFFFFF"
                                               FontSize="18"
                                               Margin="0,0,7,0"/>
                                <TextBlock Text="Tải lên Cloud"
                                           Foreground="#FFFFFF"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                    </StackPanel>
                </Grid>

                <!-- THỐNG KÊ NHANH -->
                <Grid Grid.Row="1" Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Style="{StaticResource MiniCardStyle}"
                            Margin="0,0,12,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Width="46"
                                    Height="46"
                                    CornerRadius="16"
                                    Background="#EFF6FF"
                                    Margin="0,0,14,0">
                                <ui:SymbolIcon Symbol="ArrowUpload24"
                                               Foreground="#2563EB"
                                               FontSize="24"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Tổng tài liệu"
                                           Foreground="#64748B"
                                           FontSize="13"/>
                                <TextBlock Text="1,234"
                                           Foreground="#0F172A"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1"
                            Style="{StaticResource MiniCardStyle}"
                            Margin="0,0,12,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Width="46"
                                    Height="46"
                                    CornerRadius="16"
                                    Background="#ECFDF5"
                                    Margin="0,0,14,0">
                                <ui:SymbolIcon Symbol="Scan24"
                                               Foreground="#059669"
                                               FontSize="24"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Đã OCR"
                                           Foreground="#64748B"
                                           FontSize="13"/>
                                <TextBlock Text="86%"
                                           Foreground="#0F172A"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2"
                            Style="{StaticResource MiniCardStyle}"
                            Margin="0,0,12,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Width="46"
                                    Height="46"
                                    CornerRadius="16"
                                    Background="#F5F3FF"
                                    Margin="0,0,14,0">
                                <ui:SymbolIcon Symbol="Bot24"
                                               Foreground="#7C3AED"
                                               FontSize="24"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Tác vụ AI"
                                           Foreground="#64748B"
                                           FontSize="13"/>
                                <TextBlock Text="03 đang chạy"
                                           Foreground="#0F172A"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="3"
                            Style="{StaticResource MiniCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Width="46"
                                    Height="46"
                                    CornerRadius="16"
                                    Background="#FEF3C7"
                                    Margin="0,0,14,0">
                                <ui:SymbolIcon Symbol="Star24"
                                               Foreground="#D97706"
                                               FontSize="24"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Dung lượng Cloud"
                                           Foreground="#64748B"
                                           FontSize="13"/>
                                <TextBlock Text="7.8 / 15 GB"
                                           Foreground="#0F172A"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <!-- MAIN AREA -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="320"/>
                    </Grid.ColumnDefinitions>

                    <!-- DANH SÁCH TÀI LIỆU -->
                    <Border Grid.Column="0"
                            Style="{StaticResource GlassCardStyle}"
                            Padding="20"
                            Margin="0,0,18,0">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- FILTER + ACTION -->
                            <Grid Grid.Row="0" Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Danh sách tài liệu"
                                               Style="{StaticResource SectionTitleStyle}"/>
                                    <TextBlock Text="Theo dõi tài liệu, phiên bản, trạng thái mã hóa, upload và kết quả xử lý AI/OCR."
                                               Style="{StaticResource SmallMutedTextStyle}"
                                               Margin="0,4,0,0"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">

                                    <Border Style="{StaticResource RoundedSearchBorderStyle}"
                                            Width="300"
                                            Margin="0,0,10,0">
                                        <ui:TextBox PlaceholderText="Tìm tài liệu, hash, danh mục..."
                                                    Icon="{ui:SymbolIcon Search24}"
                                                    Style="{StaticResource SearchTextBoxStyle}"/>
                                    </Border>

                                    <ComboBox Width="160"
                                              Height="46"
                                              SelectedIndex="0"
                                              FontSize="13">
                                        <ComboBoxItem Content="Tất cả"/>
                                        <ComboBoxItem Content="Cá nhân"/>
                                        <ComboBoxItem Content="Nhóm lưu trữ"/>
                                        <ComboBoxItem Content="Đã OCR"/>
                                        <ComboBoxItem Content="Đã mã hóa"/>
                                        <ComboBoxItem Content="Thùng rác"/>
                                    </ComboBox>

                                </StackPanel>
                            </Grid>

                            <!-- ACTION BAR -->
                            <Border Grid.Row="1"
                                    CornerRadius="20"
                                    Background="#F8FAFC"
                                    BorderBrush="#D8E6FF"
                                    BorderThickness="1"
                                    Padding="14"
                                    Margin="0,0,0,16">

                                <DockPanel>
                                    <StackPanel Orientation="Horizontal"
                                                DockPanel.Dock="Left">

                                        <Button x:Name="BtnRunOcr"
                                                Style="{StaticResource PrimaryActionButtonStyle}"
                                                Margin="0,0,10,0">
                                            <StackPanel Orientation="Horizontal">
                                                <ui:SymbolIcon Symbol="Scan24"
                                                               Foreground="#FFFFFF"
                                                               FontSize="18"
                                                               Margin="0,0,7,0"/>
                                                <TextBlock Text="Quét OCR"
                                                           Foreground="#FFFFFF"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>

                                        <Button x:Name="BtnAskAi"
                                                Style="{StaticResource SecondaryActionButtonStyle}"
                                                Margin="0,0,10,0">
                                            <StackPanel Orientation="Horizontal">
                                                <ui:SymbolIcon Symbol="Bot24"
                                                               Foreground="#7C3AED"
                                                               FontSize="18"
                                                               Margin="0,0,7,0"/>
                                                <TextBlock Text="Hỏi AI"
                                                           Foreground="#0F172A"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>

                                        <Button x:Name="BtnBatchClassify"
                                                Style="{StaticResource SecondaryActionButtonStyle}"
                                                Margin="0,0,10,0">
                                            <TextBlock Text="AI phân loại"
                                                       Foreground="#0F172A"
                                                       VerticalAlignment="Center"/>
                                        </Button>

                                        <Button x:Name="BtnShare"
                                                Style="{StaticResource SecondaryActionButtonStyle}"
                                                Margin="0,0,10,0">
                                            <StackPanel Orientation="Horizontal">
                                                <ui:SymbolIcon Symbol="Person24"
                                                               Foreground="#2563EB"
                                                               FontSize="18"
                                                               Margin="0,0,7,0"/>
                                                <TextBlock Text="Chia sẻ"
                                                           Foreground="#0F172A"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>

                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Right"
                                                DockPanel.Dock="Right">

                                        <Button x:Name="BtnDownload"
                                                Style="{StaticResource SecondaryActionButtonStyle}"
                                                Margin="0,0,10,0">
                                            <StackPanel Orientation="Horizontal">
                                                <ui:SymbolIcon Symbol="ArrowDownload24"
                                                               Foreground="#059669"
                                                               FontSize="18"
                                                               Margin="0,0,7,0"/>
                                                <TextBlock Text="Tải xuống"
                                                           Foreground="#0F172A"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>

                                        <Button x:Name="BtnDelete"
                                                Style="{StaticResource SecondaryActionButtonStyle}">
                                            <StackPanel Orientation="Horizontal">
                                                <ui:SymbolIcon Symbol="Delete24"
                                                               Foreground="#EF4444"
                                                               FontSize="18"
                                                               Margin="0,0,7,0"/>
                                                <TextBlock Text="Xóa"
                                                           Foreground="#0F172A"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>

                                    </StackPanel>
                                </DockPanel>
                            </Border>

                            <!-- DATA GRID -->
                            <Border Grid.Row="2"
                                    CornerRadius="20"
                                    Background="#FFFFFF"
                                    BorderBrush="#D8E6FF"
                                    BorderThickness="1"
                                    ClipToBounds="True">

                                <DataGrid AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="Horizontal"
                                          EnableRowVirtualization="True"
                                          EnableColumnVirtualization="True"
                                          VirtualizingPanel.IsVirtualizing="True"
                                          VirtualizingPanel.VirtualizationMode="Recycling"
                                          VirtualizingPanel.ScrollUnit="Pixel"
                                          ScrollViewer.CanContentScroll="True"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                          RowHeight="46"
                                          AlternationCount="2">

                                    <DataGrid.Columns>

                                        <DataGridTextColumn Header="Mã tài liệu"
                                                            Binding="{Binding Id}"
                                                            Width="115"/>

                                        <DataGridTextColumn Header="Tên tài liệu"
                                                            Binding="{Binding TenTaiLieu}"
                                                            Width="*"/>

                                        <DataGridTextColumn Header="Không gian"
                                                            Binding="{Binding TenNhom}"
                                                            Width="135"/>

                                        <DataGridTextColumn Header="Danh mục"
                                                            Binding="{Binding TenDanhMuc}"
                                                            Width="120"/>

                                        <DataGridTextColumn Header="Phiên bản"
                                                            Binding="{Binding PhienBan}"
                                                            Width="86"/>

                                        <DataGridTextColumn Header="Dung lượng"
                                                            Binding="{Binding KichThuocHienThi}"
                                                            Width="105"/>

                                        <DataGridTextColumn Header="Mã hóa"
                                                            Binding="{Binding DaMaHoa}"
                                                            Width="88"/>

                                        <DataGridTextColumn Header="Upload"
                                                            Binding="{Binding TrangThaiUpload}"
                                                            Width="110"/>

                                        <DataGridTextColumn Header="AI/OCR"
                                                            Binding="{Binding TrangThaiAi}"
                                                            Width="110"/>

                                        <DataGridTextColumn Header="Ngày cập nhật"
                                                            Binding="{Binding NgayCapNhat, StringFormat='dd/MM/yyyy'}"
                                                            Width="120"/>

                                        <DataGridTemplateColumn Header="Thao tác" Width="160">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal"
                                                                HorizontalAlignment="Center">

                                                        <Button Style="{StaticResource MiniIconButtonStyle}"
                                                                ToolTip="Xem tài liệu"
                                                                Margin="2,0">
                                                            <ui:SymbolIcon Symbol="Eye24"
                                                                           FontSize="15"
                                                                           Foreground="#0F172A"/>
                                                        </Button>

                                                        <Button Style="{StaticResource MiniIconButtonStyle}"
                                                                ToolTip="OCR"
                                                                Margin="2,0">
                                                            <ui:SymbolIcon Symbol="Scan24"
                                                                           FontSize="15"
                                                                           Foreground="#2563EB"/>
                                                        </Button>

                                                        <Button Style="{StaticResource MiniIconButtonStyle}"
                                                                ToolTip="Tải xuống"
                                                                Margin="2,0">
                                                            <ui:SymbolIcon Symbol="ArrowDownload24"
                                                                           FontSize="15"
                                                                           Foreground="#059669"/>
                                                        </Button>

                                                        <Button Style="{StaticResource MiniIconButtonStyle}"
                                                                ToolTip="Xóa"
                                                                Margin="2,0">
                                                            <ui:SymbolIcon Symbol="Delete24"
                                                                           FontSize="15"
                                                                           Foreground="#EF4444"/>
                                                        </Button>

                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>

                        </Grid>
                    </Border>

                    <!-- PANEL PHẢI -->
                    <StackPanel Grid.Column="1">

                        <!-- CLOUD QUOTA -->
                        <Border Style="{StaticResource MiniCardStyle}"
                                Margin="0,0,0,14">
                            <StackPanel>
                                <Border Width="50"
                                        Height="50"
                                        CornerRadius="18"
                                        Background="#EFF6FF"
                                        HorizontalAlignment="Left"
                                        Margin="0,0,0,14">
                                    <ui:SymbolIcon Symbol="ArrowUpload24"
                                                   Foreground="#2563EB"
                                                   FontSize="26"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                </Border>

                                <TextBlock Text="Cloudflare R2"
                                           Style="{StaticResource SectionTitleStyle}"/>

                                <TextBlock Text="Đồng bộ file đã mã hóa, kiểm tra hash chống trùng và quản lý trạng thái upload."
                                           Style="{StaticResource SmallMutedTextStyle}"
                                           TextWrapping="Wrap"
                                           LineHeight="20"
                                           Margin="0,6,0,14"/>

                                <ProgressBar Value="52"
                                             Minimum="0"
                                             Maximum="100"
                                             Height="8"
                                             Foreground="#2563EB"
                                             Background="#DBEAFE"/>

                                <TextBlock Foreground="#64748B"
                                           FontSize="12"
                                           Margin="0,8,0,0">
                                    <Run Text="Đã dùng "/>
                                    <Run Text="7.8 GB" FontWeight="Bold"/>
                                    <Run Text=" / 15 GB"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- AI JOB -->
                        <Border Style="{StaticResource MiniCardStyle}"
                                Margin="0,0,0,14">
                            <StackPanel>
                                <Border Width="50"
                                        Height="50"
                                        CornerRadius="18"
                                        Background="#F5F3FF"
                                        HorizontalAlignment="Left"
                                        Margin="0,0,0,14">
                                    <ui:SymbolIcon Symbol="Bot24"
                                                   Foreground="#7C3AED"
                                                   FontSize="26"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                </Border>

                                <TextBlock Text="Tác vụ AI nền"
                                           Style="{StaticResource SectionTitleStyle}"/>

                                <TextBlock Text="Theo dõi Batch OCR, phân loại tài liệu và hỏi đáp AI theo hàng đợi tác vụ nền."
                                           Style="{StaticResource SmallMutedTextStyle}"
                                           TextWrapping="Wrap"
                                           LineHeight="20"
                                           Margin="0,6,0,14"/>

                                <ProgressBar Value="64"
                                             Minimum="0"
                                             Maximum="100"
                                             Height="8"
                                             Foreground="#7C3AED"
                                             Background="#EDE9FE"/>

                                <TextBlock Foreground="#64748B"
                                           FontSize="12"
                                           Margin="0,8,0,14">
                                    <Run Text="Tiến độ hiện tại: "/>
                                    <Run Text="64%" FontWeight="Bold"/>
                                    <Run Text=" - 16/25 file"/>
                                </TextBlock>

                                <Button x:Name="BtnOpenAiJobs"
                                        Style="{StaticResource SecondaryActionButtonStyle}">
                                    <TextBlock Text="Xem hàng đợi AI"
                                               Foreground="#0F172A"
                                               VerticalAlignment="Center"/>
                                </Button>
                            </StackPanel>
                        </Border>

                        <!-- SECURITY -->
                        <Border Style="{StaticResource MiniCardStyle}"
                                Margin="0,0,0,14">
                            <StackPanel>
                                <Border Width="50"
                                        Height="50"
                                        CornerRadius="18"
                                        Background="#ECFDF5"
                                        HorizontalAlignment="Left"
                                        Margin="0,0,0,14">
                                    <ui:SymbolIcon Symbol="Settings24"
                                                   Foreground="#059669"
                                                   FontSize="26"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                </Border>

                                <TextBlock Text="Bảo mật E2EE"
                                           Style="{StaticResource SectionTitleStyle}"/>

                                <TextBlock Text="File chia sẻ sẽ dùng FileKey đã mã hóa bằng Public Key PGP của người nhận."
                                           Style="{StaticResource SmallMutedTextStyle}"
                                           TextWrapping="Wrap"
                                           LineHeight="20"
                                           Margin="0,6,0,14"/>

                                <Button x:Name="BtnEncryptShare"
                                        Style="{StaticResource SecondaryActionButtonStyle}">
                                    <TextBlock Text="Chia sẻ bảo mật"
                                               Foreground="#0F172A"
                                               VerticalAlignment="Center"/>
                                </Button>
                            </StackPanel>
                        </Border>

                        <!-- GROUP STORAGE -->
                        <Border CornerRadius="24"
                                BorderBrush="#FDE68A"
                                BorderThickness="1"
                                Padding="20"
                                Background="#FFFBEB">
                            <StackPanel>
                                <Border Width="50"
                                        Height="50"
                                        CornerRadius="18"
                                        Background="#FEF3C7"
                                        HorizontalAlignment="Left"
                                        Margin="0,0,0,14">
                                    <ui:SymbolIcon Symbol="Star24"
                                                   Foreground="#D97706"
                                                   FontSize="26"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                </Border>

                                <TextBlock Text="Không gian nhóm"
                                           Foreground="#92400E"
                                           FontSize="17"
                                           FontWeight="Bold"/>

                                <TextBlock Text="Quản lý tài liệu dùng chung, quyền xem/thêm/sửa/xóa/chia sẻ theo bitmask."
                                           Foreground="#92400E"
                                           FontSize="13"
                                           TextWrapping="Wrap"
                                           LineHeight="20"
                                           Margin="0,6,0,14"/>

                                <Button x:Name="BtnOpenGroupStorage"
                                        Style="{StaticResource PrimaryActionButtonStyle}"
                                        Background="#F59E0B"
                                        BorderBrush="#F59E0B">
                                    <TextBlock Text="Mở nhóm lưu trữ"
                                               Foreground="#FFFFFF"
                                               VerticalAlignment="Center"/>
                                </Button>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Grid>

                <!-- FOOTER -->
                <Border Grid.Row="3"
                        CornerRadius="20"
                        Background="#EEFFFFFF"
                        BorderBrush="#D8E6FF"
                        BorderThickness="1"
                        Padding="16,12"
                        Margin="0,18,0,0">

                    <DockPanel>
                        <TextBlock DockPanel.Dock="Left"
                                   VerticalAlignment="Center"
                                   Foreground="#64748B"
                                   FontSize="13">
                            <Run Text="Hiển thị "/>
                            <Run Text="50" FontWeight="Bold" Foreground="#0F172A"/>
                            <Run Text=" tài liệu/trang  |  Đã chọn: "/>
                            <Run Text="0" FontWeight="Bold" Foreground="#0F172A"/>
                            <Run Text="  |  Trạng thái Cloud: "/>
                            <Run Text="Sẵn sàng" FontWeight="Bold" Foreground="#059669"/>
                        </TextBlock>

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    DockPanel.Dock="Right">

                            <Button Style="{StaticResource SecondaryActionButtonStyle}"
                                    Margin="0,0,10,0">
                                <TextBlock Text="Trước"
                                           Foreground="#0F172A"
                                           VerticalAlignment="Center"/>
                            </Button>

                            <Button Style="{StaticResource SecondaryActionButtonStyle}">
                                <TextBlock Text="Sau"
                                           Foreground="#0F172A"
                                           VerticalAlignment="Center"/>
                            </Button>

                        </StackPanel>
                    </DockPanel>
                </Border>

            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>