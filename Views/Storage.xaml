<ui:FluentWindow x:Class="TroLySoCaNhan.Views.Storage"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 mc:Ignorable="d"
                 Title="Kho lưu trữ tài liệu"
                 Height="860" Width="1360"
                 MinHeight="760" MinWidth="1180"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True"
                 WindowStartupLocation="CenterScreen"
                 TextOptions.TextFormattingMode="Display"
                 TextOptions.TextRenderingMode="ClearType"
                 Background="Transparent">

    <ui:FluentWindow.Resources>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#0F172A"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#64748B"/>
        <SolidColorBrush x:Key="BluePrimaryBrush" Color="#2563EB"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#EEFFFFFF"/>
        <SolidColorBrush x:Key="InputBackgroundBrush" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="InputBorderBrush" Color="#D8E6FF"/>

        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <Style x:Key="PageTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="SmallMutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="FolderCardStyle" TargetType="Button">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Width" Value="200"/>
            <Setter Property="Height" Value="56"/>
            <Setter Property="Margin" Value="0,0,14,14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12" Padding="12,0">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#EFF6FF"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#BFDBFE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GlassCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="24"/>
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="8" Opacity="0.1" Color="#2563EB"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MiniCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16"/>
        </Style>

        <Style x:Key="SearchTextBoxStyle" TargetType="{x:Type ui:TextBox}">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="PrimaryActionButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="BorderBrush" Value="#2563EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryActionButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#EFF6FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MiniIconButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#EFF6FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="Transparent"/>
            <Setter Property="AlternatingRowBackground" Value="#F8FAFC"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource InputBorderBrush}"/>
            <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#EFF6FF"/>
            <Setter Property="Foreground" Value="#1E3A8A"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="Height" Value="46"/>
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Ellipse Width="480" Height="480" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-190,-190,0,0" Opacity="0.25">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#60A5FA" Offset="0"/>
                    <GradientStop Color="#00FFFFFF" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
            <Ellipse.Effect>
                <BlurEffect Radius="50"/>
            </Ellipse.Effect>
        </Ellipse>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <ui:TitleBar Grid.Row="0" Title="Quản lý Tài liệu" Background="Transparent" Foreground="#0F172A">
                <ui:TitleBar.Icon>
                    <ui:SymbolIcon Symbol="FolderOpen24" Foreground="#2563EB"/>
                </ui:TitleBar.Icon>
            </ui:TitleBar>

            <Grid Grid.Row="1" Margin="24,10,24,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Kho lưu trữ tài liệu" Style="{StaticResource PageTitleStyle}"/>
                        <TextBlock Text="Không gian mã hóa an toàn cho tài liệu cá nhân và nhóm làm việc." Style="{StaticResource SmallMutedTextStyle}" Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding OpenCreateFolderDialogCommand}" Margin="0,0,10,0">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="FolderAdd24" FontSize="18" Foreground="#0F172A" Margin="0,0,8,0"/>
                                <TextBlock Text="Thư mục mới"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource PrimaryActionButtonStyle}" Command="{Binding UploadTaiLieuCommand}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="DocumentAdd24" FontSize="18" Margin="0,0,8,0"/>
                                <TextBlock Text="Tải tệp lên"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource MiniCardStyle}" Margin="0,0,12,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="42" Height="42" CornerRadius="12" Background="#EFF6FF" Margin="0,0,14,0">
                                <ui:SymbolIcon Symbol="Document24" Foreground="#2563EB" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Tổng tài liệu" Foreground="#64748B" FontSize="12"/>
                                <TextBlock Text="{Binding TotalItems}" Foreground="#0F172A" FontSize="20" FontWeight="Bold"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource MiniCardStyle}" Margin="0,0,12,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="42" Height="42" CornerRadius="12" Background="#ECFDF5" Margin="0,0,14,0">
                                <ui:SymbolIcon Symbol="CloudCheckmark24" Foreground="#059669" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Đã đồng bộ Cloud" Foreground="#64748B" FontSize="12"/>
                                <TextBlock Text="{Binding TotalCloudFiles, StringFormat='{}{0} File'}" Foreground="#0F172A" FontSize="20" FontWeight="Bold"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource MiniCardStyle}" Margin="0,0,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="42" Height="42" CornerRadius="12" Background="#FEF3C7" Margin="0,0,14,0">
                                <ui:SymbolIcon Symbol="DataPie24" Foreground="#D97706" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Dung lượng đã dùng" Foreground="#64748B" FontSize="12"/>
                                <TextBlock Text="{Binding UsedStorageText}" Foreground="#0F172A" FontSize="20" FontWeight="Bold"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="340"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource GlassCardStyle}" Margin="0,0,16,0" Padding="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="#F8FAFC" BorderBrush="#D8E6FF" BorderThickness="0,0,0,1" CornerRadius="24,24,0,0" Padding="20,14">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                        <ui:SymbolIcon Symbol="FolderOpen24" Foreground="#2563EB" FontSize="20" Margin="0,0,10,0"/>
                                        <Button Content="Trang chủ" Command="{Binding GoToHomeCommand}" Background="Transparent" BorderThickness="0" Foreground="#2563EB" FontWeight="Bold" FontSize="15" Cursor="Hand" Padding="4"/>
                                        <TextBlock Text="/" Foreground="#94A3B8" FontSize="16" Margin="6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding CurrentFolderName}" Foreground="#0F172A" FontWeight="Bold" FontSize="15" VerticalAlignment="Center" Margin="4,0"/>
                                    </StackPanel>

                                    <ui:TextBox Grid.Column="1" Width="240" Height="36" PlaceholderText="Tìm file, thư mục..." 
                                                Icon="{ui:SymbolIcon Search24}" Style="{StaticResource SearchTextBoxStyle}"
                                                Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}">
                                        <ui:TextBox.InputBindings>
                                            <KeyBinding Key="Return" Command="{Binding SearchCommand}"/>
                                        </ui:TextBox.InputBindings>
                                    </ui:TextBox>
                                </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20">
                                <StackPanel>

                                    <TextBlock Text="Thư mục" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,12"/>
                                    <ItemsControl ItemsSource="{Binding Folders}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Style="{StaticResource FolderCardStyle}" Command="{Binding DataContext.OpenFolderCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <ui:SymbolIcon Grid.Column="0" Symbol="Folder24" Foreground="#3B82F6" FontSize="26" Margin="0,0,12,0"/>
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding TenThuMuc}" Foreground="#0F172A" FontSize="14" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Text="{Binding SoLuongFile, StringFormat='{}{0} mục'}" Foreground="#64748B" FontSize="12" Margin="0,2,0,0"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <TextBlock Text="Tệp tin" Style="{StaticResource SectionTitleStyle}" Margin="0,16,0,12"/>
                                    <Border CornerRadius="16" BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1" ClipToBounds="True">
                                        <DataGrid ItemsSource="{Binding TaiLieus}" SelectedItem="{Binding SelectedTaiLieu}" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" GridLinesVisibility="Horizontal">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Tên tài liệu" Binding="{Binding TenFile}" Width="*"/>
                                                <DataGridTextColumn Header="Dung lượng" Binding="{Binding DungLuongHienThi}" Width="100"/>
                                                <DataGridTextColumn Header="Trạng thái" Binding="{Binding TrangThai}" Width="150"/>
                                                <DataGridTextColumn Header="Ngày tải lên" Binding="{Binding NgayTao, StringFormat='dd/MM/yyyy'}" Width="110"/>
                                                <DataGridTemplateColumn Header="Thao tác" Width="Auto">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                                <Button Style="{StaticResource MiniIconButtonStyle}" ToolTip="Xem chi tiết" Margin="2,0" Command="{Binding DataContext.OpenTaiLieuCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}">
                                                                    <ui:SymbolIcon Symbol="Eye24" FontSize="16" Foreground="#0F172A"/>
                                                                </Button>
                                                                <Button ToolTip="Đồng bộ lên Cloud" Margin="2,0" Command="{Binding DataContext.UploadCloudCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}">
                                                                    <Button.Style>
                                                                        <Style TargetType="Button" BasedOn="{StaticResource MiniIconButtonStyle}">
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsOnCloud}" Value="True">
                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Button.Style>
                                                                    <ui:SymbolIcon Symbol="CloudArrowUp24" FontSize="16" Foreground="#059669"/>
                                                                </Button>
                                                                <Button ToolTip="Gỡ khỏi Cloud" Margin="2,0" Command="{Binding DataContext.RemoveFromCloudCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}">
                                                                    <Button.Style>
                                                                        <Style TargetType="Button" BasedOn="{StaticResource MiniIconButtonStyle}">
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsOnCloud}" Value="False">
                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Button.Style>
                                                                    <ui:SymbolIcon Symbol="CloudDismiss24" FontSize="16" Foreground="#D97706"/>
                                                                </Button>
                                                                <Button Style="{StaticResource MiniIconButtonStyle}" ToolTip="Tải xuống" Margin="2,0" Command="{Binding DataContext.DownloadTaiLieuCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}">
                                                                    <ui:SymbolIcon Symbol="ArrowDownload24" FontSize="16" Foreground="#2563EB"/>
                                                                </Button>
                                                                <Button Style="{StaticResource MiniIconButtonStyle}" ToolTip="Xóa vĩnh viễn" Margin="2,0" Command="{Binding DataContext.DeleteTaiLieuCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}">
                                                                    <ui:SymbolIcon Symbol="Delete24" FontSize="16" Foreground="#EF4444"/>
                                                                </Button>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="1">
                        <Border Style="{StaticResource MiniCardStyle}" Margin="0,0,0,16">
                            <StackPanel>
                                <Border Width="48" Height="48" CornerRadius="14" Background="#F8FAFC" BorderBrush="#D8E6FF" BorderThickness="1" HorizontalAlignment="Left" Margin="0,0,0,12">
                                    <ui:SymbolIcon Symbol="HardDrive24" Foreground="#0F172A" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Không gian Local Vault" Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock Text="Nơi lưu trữ file đã mã hóa cục bộ. Việc đổi ổ đĩa sẽ tự động sao chép Private Key sang nhà mới." Style="{StaticResource SmallMutedTextStyle}" TextWrapping="Wrap" LineHeight="20" Margin="0,0,0,16"/>

                                <Button Style="{StaticResource SecondaryActionButtonStyle}" Height="40" Margin="0,0,0,8" Command="{Binding OpenLocalFolderCommand}" HorizontalAlignment="Stretch">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="FolderOpen24" FontSize="16" Margin="0,0,8,0"/>
                                        <TextBlock Text="Mở thư mục hiện tại" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button Style="{StaticResource SecondaryActionButtonStyle}" Height="40" Command="{Binding ChangeLocalFolderCommand}" HorizontalAlignment="Stretch">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="ArrowSwap24" FontSize="16" Margin="0,0,8,0"/>
                                        <TextBlock Text="Thay đổi phân vùng lưu trữ" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource MiniCardStyle}" Margin="0,0,0,16">
                            <StackPanel>
                                <Border Width="48" Height="48" CornerRadius="14" Background="#EFF6FF" HorizontalAlignment="Left" Margin="0,0,0,12">
                                    <ui:SymbolIcon Symbol="Cloud24" Foreground="#2563EB" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Hạ tầng Đám mây (R2)" Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock Text="Quản lý đồng bộ file mã hóa, chống trùng lặp dữ liệu và kiểm soát băng thông." Style="{StaticResource SmallMutedTextStyle}" TextWrapping="Wrap" LineHeight="20" Margin="0,0,0,16"/>

                                <Button Style="{StaticResource PrimaryActionButtonStyle}" Height="40" Command="{Binding UploadCloudCommand}" HorizontalAlignment="Stretch" Margin="0,0,0,12">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="CloudArrowUp24" Foreground="White" FontSize="16" Margin="0,0,8,0"/>
                                        <TextBlock Text="Đồng bộ file đang chọn" Foreground="White" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button Style="{StaticResource SecondaryActionButtonStyle}" Height="40" Command="{Binding SearchCommand}" HorizontalAlignment="Stretch">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="ArrowClockwise24" FontSize="16" Margin="0,0,8,0"/>
                                        <TextBlock Text="Làm mới trạng thái Cloud" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>

        <Grid Background="#66000000" Visibility="{Binding IsCreateFolderDialogOpen, Converter={StaticResource BoolToVisibility}}" Panel.ZIndex="100">
            <Border Width="420" Background="{StaticResource SurfaceBrush}" CornerRadius="16" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="28">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="8" Opacity="0.15" Color="#0F172A"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Tạo thư mục mới" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                    <TextBlock Text="Nhập tên thư mục để phân loại tài liệu của bạn." Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,20"/>

                    <TextBlock Text="Tên thư mục" Style="{StaticResource FieldLabelStyle}" Margin="0,0,0,6"/>
                    <ui:TextBox PlaceholderText="Ví dụ: Tài liệu học tập, Hợp đồng..." Text="{Binding NewFolderName, UpdateSourceTrigger=PropertyChanged}" Height="42" Margin="0,0,0,24"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Hủy bỏ" Style="{StaticResource SecondaryActionButtonStyle}" Command="{Binding CancelCreateFolderCommand}" HorizontalAlignment="Stretch"/>
                        <Button Grid.Column="2" Content="Tạo mới" Style="{StaticResource PrimaryActionButtonStyle}" Command="{Binding ConfirmCreateFolderCommand}" HorizontalAlignment="Stretch"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</ui:FluentWindow>