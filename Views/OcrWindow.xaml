<ui:FluentWindow x:Class="TroLySoCaNhan.Views.OcrWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 mc:Ignorable="d"
                 Title="Trợ lý AI - Quét tài liệu (OCR)" 
                 Height="680" Width="1080"
                 MinHeight="600" MinWidth="900"
                 WindowBackdropType="Mica"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True"
                 TextOptions.TextFormattingMode="Display"
                 TextOptions.TextRenderingMode="ClearType"
                 Background="Transparent">

    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <Style x:Key="GlassCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="BorderBrush" Value="#D8E6FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.06" Color="#2563EB"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MiniDangerButton" TargetType="Button">
            <Setter Property="Background" Value="#FEE2E2"/>
            <Setter Property="Foreground" Value="#EF4444"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FECACA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Trợ lý AI - Quét tài liệu (OCR)" Foreground="#0F172A" Background="Transparent">
            <ui:TitleBar.Icon>
                <ui:SymbolIcon Symbol="Scan24" Foreground="#2563EB"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <Grid Grid.Row="1" Margin="24,10,24,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="Trích xuất văn bản (Gemini AI OCR)" FontSize="26" FontWeight="Bold" Foreground="#0F172A"/>
                <TextBlock Text="Phân tích bố cục, đọc chữ in và chữ viết tay với độ chính xác cao." Foreground="#64748B" FontSize="14" Margin="0,4,0,0"/>
            </StackPanel>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="5.5*"/>
                    <ColumnDefinition Width="4.5*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="0,0,16,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource GlassCardStyle}" Margin="0,0,0,16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Danh sách tài liệu cần quét" FontWeight="Bold" FontSize="15" Foreground="#0F172A"/>
                                    <TextBlock Text="{Binding SelectedFiles.Count, StringFormat='Đã chọn {0} file'}" Foreground="#2563EB" FontWeight="SemiBold" FontSize="12" Margin="0,2,0,0"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <ui:Button Content="Xóa tất cả" Icon="{ui:SymbolIcon Delete24}" Command="{Binding ClearFilesCommand}" Appearance="Danger" Margin="0,0,8,0" Padding="12,6"/>
                                    <ui:Button Content="Thêm File..." Icon="{ui:SymbolIcon Add24}" Command="{Binding SelectFilesCommand}" Appearance="Primary" Padding="12,6"/>
                                </StackPanel>
                            </Grid>

                            <Border Grid.Row="1" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Padding="8">
                                <ListBox ItemsSource="{Binding SelectedFiles}" Background="Transparent" BorderThickness="0">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,4,0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <ui:SymbolIcon Grid.Column="0" Symbol="Image24" Foreground="#64748B" Margin="0,0,10,0"/>
                                                <TextBlock Grid.Column="1" Text="{Binding}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" FontSize="13" Foreground="#334155" ToolTip="{Binding}"/>

                                                <Button Grid.Column="2" Style="{StaticResource MiniDangerButton}" Command="{Binding DataContext.RemoveFileCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" ToolTip="Loại bỏ file này">
                                                    <ui:SymbolIcon Symbol="Dismiss24" FontSize="12"/>
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource GlassCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Tùy chỉnh đầu ra (Word)" FontWeight="Bold" FontSize="15" Foreground="#0F172A" Margin="0,0,0,12"/>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ui:TextBox Text="{Binding SaveDirectory, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" PlaceholderText="Thư mục lưu..." Height="38" Margin="0,0,8,0" Icon="{ui:SymbolIcon Folder24}"/>
                                <ui:Button Grid.Column="1" Content="Đổi thư mục" Command="{Binding SelectSaveDirCommand}" Appearance="Secondary" Height="38"/>
                            </Grid>

                            <ui:TextBox Text="{Binding BaseFileName, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Tên file xuất ra (VD: BaoCao_KetQua)" Icon="{ui:SymbolIcon DocumentText24}" Height="38" Margin="0,0,0,16"/>

                            <StackPanel Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVisibility}}" Margin="0,0,0,12">
                                <DockPanel Margin="0,0,0,4">
                                    <TextBlock Text="{Binding ProgressValue, StringFormat='{}{0:F0}%'}" FontWeight="Bold" Foreground="#2563EB" DockPanel.Dock="Right"/>
                                    <TextBlock Text="{Binding ProgressText}" FontWeight="SemiBold" Foreground="#2563EB" TextTrimming="CharacterEllipsis"/>
                                </DockPanel>
                                <ProgressBar Value="{Binding ProgressValue}" Minimum="0" Maximum="100" Height="6" Foreground="#2563EB" Background="#DBEAFE"/>
                            </StackPanel>

                            <ui:Button Content="Gửi Tác Vụ Quét OCR (Gemini AI)" Icon="{ui:SymbolIcon Bot24}" Command="{Binding StartOcrCommand}" Appearance="Primary" HorizontalAlignment="Stretch" Height="48" FontSize="16" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Grid.Column="1" Background="#0F172A" CornerRadius="16" Padding="16">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="15" ShadowDepth="0" Opacity="0.3"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="0,0,0,12">
                            <ui:SymbolIcon Symbol="Code24" Foreground="#10B981" FontSize="18" DockPanel.Dock="Left" Margin="0,0,8,0"/>
                            <TextBlock Text="Nhật ký Hệ thống (AI Logs)" FontWeight="Bold" FontSize="14" Foreground="#F8FAFC" VerticalAlignment="Center"/>
                            <ui:Button Content="Clear" Command="{Binding ClearLogsCommand}" Appearance="Transparent" Foreground="#64748B" HorizontalAlignment="Right" Padding="8,4" FontSize="12"/>
                        </DockPanel>

                        <ListBox x:Name="LogListBox" Grid.Row="1" ItemsSource="{Binding LogMessages}" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="12" Foreground="#34D399" TextWrapping="Wrap" Margin="0,2"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>