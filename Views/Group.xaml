<ui:FluentWindow x:Class="TroLySoCaNhan.Views.Group"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:local="clr-namespace:TroLySoCaNhan.Views"
                 mc:Ignorable="d"
                 Title="Nhóm lưu trữ"
                 Height="780"
                 Width="1180"
                 MinHeight="720"
                 MinWidth="1080"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True"
                 WindowStartupLocation="CenterScreen"
                 TextOptions.TextFormattingMode="Display"
                 TextOptions.TextRenderingMode="ClearType">

    <ui:FluentWindow.Resources>

        <!-- =========================
             MÀU CHỦ ĐẠO
        ========================== -->
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#0F172A"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#64748B"/>
        <SolidColorBrush x:Key="BluePrimaryBrush" Color="#2563EB"/>
        <SolidColorBrush x:Key="BlueBorderBrush" Color="#CFE3FF"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#EEFFFFFF"/>
        <SolidColorBrush x:Key="InputBackgroundBrush" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="InputBorderBrush" Color="#D8E6FF"/>

        <!-- =========================
             TEXT STYLE
        ========================== -->
        <Style x:Key="PageTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="PageSubTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="LineHeight" Value="21"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="LineHeight" Value="20"/>
        </Style>

        <!-- =========================
             CARD STYLE
        ========================== -->
        <Style x:Key="GlassCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="26"/>
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BlueBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="34"
                                      ShadowDepth="10"
                                      Opacity="0.13"
                                      Color="#2563EB"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SoftCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#D8E6FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="SearchBorderStyle" TargetType="Border">
            <Setter Property="Height" Value="44"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="SearchTextBoxStyle" TargetType="{x:Type ui:TextBox}">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="12,0,12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- =========================
             BUTTON BO TRÒN
        ========================== -->
        <Style x:Key="PrimaryButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="44"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="BorderBrush" Value="#2563EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1D4ED8"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#1D4ED8"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1E40AF"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="44"/>
            <Setter Property="MinWidth" Value="92"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#D8E6FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#EFF6FF"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#BFDBFE"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#DBEAFE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#D8E6FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#EFF6FF"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#BFDBFE"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#DBEAFE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- =========================
             DATAGRID STYLE
        ========================== -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="#FFFFFF"/>
            <Setter Property="AlternatingRowBackground" Value="#F8FAFC"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E2E8F0"/>
            <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#EFF6FF"/>
            <Setter Property="Foreground" Value="#1E3A8A"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="BorderBrush" Value="#D8E6FF"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Height" Value="46"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

    </ui:FluentWindow.Resources>

    <Grid>

        <!-- =========================
             NỀN GRADIENT
        ========================== -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FFFFFF" Offset="0.00"/>
                <GradientStop Color="#F3F9FF" Offset="0.34"/>
                <GradientStop Color="#DBEAFE" Offset="0.78"/>
                <GradientStop Color="#EFF6FF" Offset="1.00"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Ellipse Width="460"
                 Height="460"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"
                 Margin="-180,-190,0,0"
                 Opacity="0.48">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#60A5FA" Offset="0"/>
                    <GradientStop Color="#BFDBFE" Offset="0.55"/>
                    <GradientStop Color="#00FFFFFF" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
            <Ellipse.Effect>
                <BlurEffect Radius="42"/>
            </Ellipse.Effect>
        </Ellipse>

        <Ellipse Width="560"
                 Height="560"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Bottom"
                 Margin="0,0,-230,-250"
                 Opacity="0.42">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#93C5FD" Offset="0"/>
                    <GradientStop Color="#DBEAFE" Offset="0.55"/>
                    <GradientStop Color="#00FFFFFF" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
            <Ellipse.Effect>
                <BlurEffect Radius="48"/>
            </Ellipse.Effect>
        </Ellipse>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- =========================
                 TITLE BAR
            ========================== -->
            <ui:TitleBar Grid.Row="0"
                         Title="Không gian nhóm"
                         Foreground="#0F172A"
                         Background="Transparent">
                <ui:TitleBar.Icon>
                    <ui:SymbolIcon Symbol="PeopleTeam24" Foreground="#2563EB"/>
                </ui:TitleBar.Icon>
            </ui:TitleBar>

            <!-- =========================
                 CONTENT
            ========================== -->
            <Grid Grid.Row="1" Margin="28,18,28,26">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- HEADER -->
                <Grid Grid.Row="0" Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Nhóm lưu trữ"
                                   Style="{StaticResource PageTitleStyle}"/>

                        <TextBlock Text="Quản lý không gian làm việc chung, tài liệu nội bộ, thành viên và quyền truy cập theo nhóm."
                                   Style="{StaticResource PageSubTitleStyle}"
                                   Margin="0,6,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">

                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding RefreshGroupsCommand}"
                                Margin="0,0,10,0">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="ArrowClockwise24"
                                               Foreground="#2563EB"
                                               FontSize="18"
                                               Margin="0,0,7,0"/>
                                <TextBlock Text="Làm mới"
                                           Foreground="#0F172A"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding CreateGroupCommand}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Add24"
                                               Foreground="White"
                                               FontSize="18"
                                               Margin="0,0,7,0"/>
                                <TextBlock Text="Tạo nhóm"
                                           Foreground="White"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- MAIN LAYOUT -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>

                    <!-- =========================
                         SIDEBAR GROUPS
                    ========================== -->
                    <Border Grid.Column="0"
                            Style="{StaticResource GlassCardStyle}"
                            Margin="0,0,18,0">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Margin="0,0,0,14">
                                <TextBlock Text="Danh sách nhóm"
                                           Style="{StaticResource SectionTitleStyle}"/>

                                <TextBlock Text="Chọn một nhóm để xem tài liệu và thành viên."
                                           Style="{StaticResource MutedTextStyle}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>

                            <Border Grid.Row="1"
                                    Style="{StaticResource SearchBorderStyle}"
                                    Margin="0,0,0,14">
                                <ui:TextBox PlaceholderText="Tìm nhóm..."
                                            Icon="{ui:SymbolIcon Search24}"
                                            Style="{StaticResource SearchTextBoxStyle}"
                                            Text="{Binding SearchGroupKeyword, UpdateSourceTrigger=PropertyChanged}"/>
                            </Border>

                            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Groups}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Background="Transparent"
                                                    BorderBrush="Transparent"
                                                    BorderThickness="0"
                                                    Padding="0"
                                                    HorizontalContentAlignment="Stretch"
                                                    Cursor="Hand"
                                                    Command="{Binding DataContext.SelectGroupCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}">

                                                <Border CornerRadius="20"
                                                        Background="#FFFFFF"
                                                        BorderBrush="#D8E6FF"
                                                        BorderThickness="1"
                                                        Padding="14"
                                                        Margin="0,0,0,10">

                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>

                                                        <Border Width="46"
                                                                Height="46"
                                                                CornerRadius="16"
                                                                Background="#EFF6FF"
                                                                Margin="0,0,12,0">
                                                            <ui:SymbolIcon Symbol="PeopleTeam24"
                                                                           Foreground="#2563EB"
                                                                           FontSize="24"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"/>
                                                        </Border>

                                                        <StackPanel Grid.Column="1">
                                                            <TextBlock Text="{Binding TenNhom}"
                                                                       Foreground="#0F172A"
                                                                       FontSize="15"
                                                                       FontWeight="Bold"
                                                                       TextWrapping="Wrap"/>

                                                            <TextBlock Foreground="#64748B"
                                                                       FontSize="12"
                                                                       Margin="0,4,0,0">
                                                                <Run Text="{Binding SoThanhVien}"/>
                                                                <Run Text=" thành viên • "/>
                                                                <Run Text="{Binding SoTaiLieu}"/>
                                                                <Run Text=" tài liệu"/>
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <!-- =========================
                         CENTER DOCUMENTS
                    ========================== -->
                    <Border Grid.Column="1"
                            Style="{StaticResource GlassCardStyle}"
                            Margin="0,0,18,0"
                            Padding="20">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Selected group header -->
                            <Grid Grid.Row="0" Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="50"
                                                Height="50"
                                                CornerRadius="18"
                                                Background="#EFF6FF"
                                                Margin="0,0,12,0">
                                            <ui:SymbolIcon Symbol="Folder24"
                                                           Foreground="#2563EB"
                                                           FontSize="26"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                        </Border>

                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding SelectedGroup.TenNhom, FallbackValue='Chưa chọn nhóm'}"
                                                       Foreground="#0F172A"
                                                       FontSize="22"
                                                       FontWeight="Bold"/>

                                            <TextBlock Text="Không gian lưu trữ chung cho tài liệu nhóm"
                                                       Foreground="#64748B"
                                                       FontSize="13"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">

                                    <Button Style="{StaticResource SecondaryButtonStyle}"
                                            Command="{Binding ShareGroupDocumentCommand}"
                                            Margin="0,0,10,0">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="Share24"
                                                           Foreground="#2563EB"
                                                           FontSize="18"
                                                           Margin="0,0,7,0"/>
                                            <TextBlock Text="Chia sẻ"
                                                       Foreground="#0F172A"/>
                                        </StackPanel>
                                    </Button>

                                    <Button Style="{StaticResource PrimaryButtonStyle}"
                                            Command="{Binding UploadGroupDocumentCommand}">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="ArrowUpload24"
                                                           Foreground="White"
                                                           FontSize="18"
                                                           Margin="0,0,7,0"/>
                                            <TextBlock Text="Upload"
                                                       Foreground="White"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>

                            <!-- Permission chips -->
                            <WrapPanel Grid.Row="1" Margin="0,0,0,16">

                                <Border CornerRadius="18"
                                        Background="#EFF6FF"
                                        BorderBrush="#BFDBFE"
                                        BorderThickness="1"
                                        Padding="12,7"
                                        Margin="0,0,8,8">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="Eye24"
                                                       Foreground="#2563EB"
                                                       FontSize="16"
                                                       Margin="0,0,6,0"/>
                                        <TextBlock Text="Xem"
                                                   Foreground="#1E3A8A"
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>

                                <Border CornerRadius="18"
                                        Background="#ECFDF5"
                                        BorderBrush="#BBF7D0"
                                        BorderThickness="1"
                                        Padding="12,7"
                                        Margin="0,0,8,8">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="Add24"
                                                       Foreground="#059669"
                                                       FontSize="16"
                                                       Margin="0,0,6,0"/>
                                        <TextBlock Text="Thêm"
                                                   Foreground="#047857"
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>

                                <Border CornerRadius="18"
                                        Background="#FEF3C7"
                                        BorderBrush="#FDE68A"
                                        BorderThickness="1"
                                        Padding="12,7"
                                        Margin="0,0,8,8">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="Edit24"
                                                       Foreground="#D97706"
                                                       FontSize="16"
                                                       Margin="0,0,6,0"/>
                                        <TextBlock Text="Sửa"
                                                   Foreground="#92400E"
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>

                                <Border CornerRadius="18"
                                        Background="#F5F3FF"
                                        BorderBrush="#DDD6FE"
                                        BorderThickness="1"
                                        Padding="12,7"
                                        Margin="0,0,8,8">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="PeopleTeam24"
                                                       Foreground="#7C3AED"
                                                       FontSize="16"
                                                       Margin="0,0,6,0"/>
                                        <TextBlock Text="Quản lý thành viên"
                                                   Foreground="#6D28D9"
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>

                            </WrapPanel>

                            <!-- Documents table -->
                            <Border Grid.Row="2"
                                    CornerRadius="20"
                                    Background="#FFFFFF"
                                    BorderBrush="#D8E6FF"
                                    BorderThickness="1"
                                    ClipToBounds="True">

                                <DataGrid ItemsSource="{Binding GroupDocuments}"
                                          SelectedItem="{Binding SelectedDocument}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="Horizontal"
                                          EnableRowVirtualization="True"
                                          EnableColumnVirtualization="True"
                                          VirtualizingPanel.IsVirtualizing="True"
                                          VirtualizingPanel.VirtualizationMode="Recycling"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                          RowHeight="46"
                                          AlternationCount="2">

                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Tên tài liệu"
                                                            Binding="{Binding TenTaiLieu}"
                                                            Width="*"/>

                                        <DataGridTextColumn Header="Loại"
                                                            Binding="{Binding DinhDang}"
                                                            Width="90"/>

                                        <DataGridTextColumn Header="Dung lượng"
                                                            Binding="{Binding DungLuongHienThi}"
                                                            Width="105"/>

                                        <DataGridTextColumn Header="Phiên bản"
                                                            Binding="{Binding PhienBan}"
                                                            Width="95"/>

                                        <DataGridTextColumn Header="Cập nhật"
                                                            Binding="{Binding NgayCapNhat, StringFormat='dd/MM/yyyy'}"
                                                            Width="115"/>

                                        <DataGridTemplateColumn Header="Thao tác" Width="150">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal"
                                                                HorizontalAlignment="Center">

                                                        <Button Style="{StaticResource IconButtonStyle}"
                                                                ToolTip="Xem"
                                                                Margin="2,0"
                                                                Command="{Binding DataContext.ViewDocumentCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                CommandParameter="{Binding}">
                                                            <ui:SymbolIcon Symbol="Eye24"
                                                                           Foreground="#2563EB"
                                                                           FontSize="15"/>
                                                        </Button>

                                                        <Button Style="{StaticResource IconButtonStyle}"
                                                                ToolTip="Tải xuống"
                                                                Margin="2,0"
                                                                Command="{Binding DataContext.DownloadDocumentCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                CommandParameter="{Binding}">
                                                            <ui:SymbolIcon Symbol="ArrowDownload24"
                                                                           Foreground="#059669"
                                                                           FontSize="15"/>
                                                        </Button>

                                                        <Button Style="{StaticResource IconButtonStyle}"
                                                                ToolTip="Xóa"
                                                                Margin="2,0"
                                                                Command="{Binding DataContext.DeleteGroupDocumentCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                CommandParameter="{Binding}">
                                                            <ui:SymbolIcon Symbol="Delete24"
                                                                           Foreground="#EF4444"
                                                                           FontSize="15"/>
                                                        </Button>

                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- =========================
                         RIGHT MEMBERS + ACTIVITY
                    ========================== -->
                    <StackPanel Grid.Column="2">

                        <!-- Members -->
                        <Border Style="{StaticResource GlassCardStyle}"
                                Padding="18"
                                Margin="0,0,0,14">
                            <StackPanel>
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="Thành viên"
                                                   Style="{StaticResource SectionTitleStyle}"/>

                                        <TextBlock Text="Quản lý quyền truy cập nhóm."
                                                   Style="{StaticResource MutedTextStyle}"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>

                                    <Button Grid.Column="1"
                                            Style="{StaticResource IconButtonStyle}"
                                            Command="{Binding AddMemberCommand}"
                                            ToolTip="Thêm thành viên">
                                        <ui:SymbolIcon Symbol="PersonAdd24"
                                                       Foreground="#2563EB"
                                                       FontSize="18"/>
                                    </Button>
                                </Grid>

                                <ItemsControl ItemsSource="{Binding Members}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="18"
                                                    Background="#FFFFFF"
                                                    BorderBrush="#D8E6FF"
                                                    BorderThickness="1"
                                                    Padding="12"
                                                    Margin="0,0,0,10">

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <Border Width="40"
                                                            Height="40"
                                                            CornerRadius="14"
                                                            Background="#EFF6FF"
                                                            Margin="0,0,10,0">
                                                        <ui:SymbolIcon Symbol="Person24"
                                                                       Foreground="#2563EB"
                                                                       FontSize="21"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"/>
                                                    </Border>

                                                    <StackPanel Grid.Column="1"
                                                                VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding TenHienThi}"
                                                                   Foreground="#0F172A"
                                                                   FontWeight="Bold"
                                                                   FontSize="14"/>

                                                        <TextBlock Text="{Binding VaiTroTrongNhom}"
                                                                   Foreground="#64748B"
                                                                   FontSize="12"
                                                                   Margin="0,3,0,0"/>
                                                    </StackPanel>

                                                    <Button Grid.Column="2"
                                                            Style="{StaticResource IconButtonStyle}"
                                                            Command="{Binding DataContext.EditMemberPermissionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            ToolTip="Sửa quyền">
                                                        <ui:SymbolIcon Symbol="Edit24"
                                                                       Foreground="#D97706"
                                                                       FontSize="15"/>
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Permission explanation -->
                        <Border Style="{StaticResource SoftCardStyle}"
                                Background="#EFF6FF"
                                BorderBrush="#BFDBFE">
                            <StackPanel>
                                <Border Width="48"
                                        Height="48"
                                        CornerRadius="17"
                                        Background="#FFFFFF"
                                        HorizontalAlignment="Left"
                                        Margin="0,0,0,12">
                                    <ui:SymbolIcon Symbol="Shield24"
                                                   Foreground="#2563EB"
                                                   FontSize="24"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                </Border>

                                <TextBlock Text="Quyền nhóm"
                                           Foreground="#0F172A"
                                           FontSize="17"
                                           FontWeight="Bold"/>

                                <TextBlock Text="Hệ thống có thể xử lý quyền dạng bitmask: Xem, Thêm, Sửa, Xóa, Chia sẻ và Quản lý thành viên."
                                           Foreground="#475569"
                                           FontSize="13"
                                           TextWrapping="Wrap"
                                           LineHeight="20"
                                           Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Activity -->
                        <Border Style="{StaticResource SoftCardStyle}"
                                Margin="0">
                            <StackPanel>
                                <TextBlock Text="Hoạt động gần đây"
                                           Style="{StaticResource SectionTitleStyle}"/>

                                <StackPanel Margin="0,6,0,0">

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <Border Width="32"
                                                Height="32"
                                                CornerRadius="12"
                                                Background="#ECFDF5"
                                                Margin="0,0,10,0">
                                            <ui:SymbolIcon Symbol="ArrowUpload24"
                                                           Foreground="#059669"
                                                           FontSize="17"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                        </Border>

                                        <StackPanel>
                                            <TextBlock Text="Có tài liệu mới được upload"
                                                       Foreground="#0F172A"
                                                       FontWeight="SemiBold"
                                                       FontSize="13"/>
                                            <TextBlock Text="Vừa xong"
                                                       Foreground="#64748B"
                                                       FontSize="12"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <Border Width="32"
                                                Height="32"
                                                CornerRadius="12"
                                                Background="#F5F3FF"
                                                Margin="0,0,10,0">
                                            <ui:SymbolIcon Symbol="PeopleTeam24"
                                                           Foreground="#7C3AED"
                                                           FontSize="17"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                        </Border>

                                        <StackPanel>
                                            <TextBlock Text="Thành viên được thêm vào nhóm"
                                                       Foreground="#0F172A"
                                                       FontWeight="SemiBold"
                                                       FontSize="13"/>
                                            <TextBlock Text="Hôm nay"
                                                       Foreground="#64748B"
                                                       FontSize="12"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="32"
                                                Height="32"
                                                CornerRadius="12"
                                                Background="#FEF3C7"
                                                Margin="0,0,10,0">
                                            <ui:SymbolIcon Symbol="Share24"
                                                           Foreground="#D97706"
                                                           FontSize="17"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                        </Border>

                                        <StackPanel>
                                            <TextBlock Text="Một tài liệu đã được chia sẻ"
                                                       Foreground="#0F172A"
                                                       FontWeight="SemiBold"
                                                       FontSize="13"/>
                                            <TextBlock Text="Gần đây"
                                                       Foreground="#64748B"
                                                       FontSize="12"/>
                                        </StackPanel>
                                    </StackPanel>

                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>