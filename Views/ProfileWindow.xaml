                                                </StackPanel>

                                                <ui:ToggleSwitch Grid.Column="2"
                                                                 IsChecked="{Binding NotificationsEnabled}"
                                                                 VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>

                                        <!-- App info -->
                                        <Border Style="{StaticResource SmallInfoCardStyle}"
                                                Padding="20"
                                                Margin="0">
                                            <StackPanel>
