                                                               Style="{StaticResource FieldLabelStyle}"/>

                                                    <TextBlock Grid.Row="4"
                                                               Grid.Column="1"
                                                               Text="2026.06.04"
                                                               Style="{StaticResource FieldValueStyle}"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                    </StackPanel>
                                </ScrollViewer>
                            </ui:TabViewItem>

                        </ui:TabView>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
