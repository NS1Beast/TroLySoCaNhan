                                                                     FontWeight="SemiBold"
                                                                     IsChecked="{Binding SelectedTheme, Mode=TwoWay, Converter={StaticResource StringEquals}, ConverterParameter=Dark}"/>
                                                    </Border>

                                                    <Border Grid.Column="2"
                                                            CornerRadius="18"
                                                            Background="#FFFFFF"
                                                            BorderBrush="#D8E6FF"
                                                            BorderThickness="1"
                                                            Padding="14">
                                                        <RadioButton GroupName="Theme"
                                                                     Content="Hệ thống"
                                                                     FontWeight="SemiBold"
                                                                     IsChecked="{Binding SelectedTheme, Mode=TwoWay, Converter={StaticResource StringEquals}, ConverterParameter=System}"/>
                                                    </Border>
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <!-- Notifications -->
                                        <Border Style="{StaticResource SmallInfoCardStyle}"
                                                Padding="20">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <Border Width="52"
                                                        Height="52"
                                                        CornerRadius="18"
                                                        Background="#EFF6FF"
                                                        Margin="0,0,16,0">
