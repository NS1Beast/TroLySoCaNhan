<ui:FluentWindow x:Class="TroLySoCaNhan.Views.ProfileWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:local="clr-namespace:TroLySoCaNhan.Views"
                 xmlns:vm="clr-namespace:TroLySoCaNhan.ViewModels"
                 xmlns:models="clr-namespace:TroLySoCaNhan.Models"
                 xmlns:helpers="clr-namespace:TroLySoCaNhan.MVVM.Converters"
                 mc:Ignorable="d"
                 Title="Hồ sơ &amp; Cài đặt"
                 Height="720" Width="980"
                 MinHeight="680" MinWidth="900"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True"
                 WindowStartupLocation="CenterOwner"
                 TextOptions.TextFormattingMode="Display"
                 TextOptions.TextRenderingMode="ClearType">

    <ui:FluentWindow.Resources>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#0F172A"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#64748B"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#94A3B8"/>
        <SolidColorBrush x:Key="BluePrimaryBrush" Color="#2563EB"/>
        <SolidColorBrush x:Key="BlueDarkBrush" Color="#1D4ED8"/>
        <SolidColorBrush x:Key="BlueSoftBrush" Color="#EFF6FF"/>
        <SolidColorBrush x:Key="BlueBorderBrush" Color="#CFE3FF"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#EEFFFFFF"/>
        <SolidColorBrush x:Key="InputBackgroundBrush" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="InputBorderBrush" Color="#D8E6FF"/>

        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <Style x:Key="PageTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="PageSubTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="LineHeight" Value="21"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="FieldValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="LineHeight" Value="20"/>
        </Style>

        <Style x:Key="GlassCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BlueBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="26"/>
            <Setter Property="Padding" Value="22"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="34" ShadowDepth="10" Opacity="0.13" Color="#2563EB"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SmallInfoCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#D8E6FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="RoundedInputBorderStyle" TargetType="Border">
            <Setter Property="Height" Value="46"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>

        <Style x:Key="ModernTextBoxStyle" TargetType="{x:Type ui:TextBox}">
            <Setter Property="Height" Value="44"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="12,0,12,0"/>
            <Setter Property="Margin" Value="0"/>
        </Style>

        <Style x:Key="ModernPasswordBoxStyle" TargetType="{x:Type ui:PasswordBox}">
            <Setter Property="Height" Value="44"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="12,0,12,0"/>
            <Setter Property="Margin" Value="0"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="46"/>
            <Setter Property="MinWidth" Value="132"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="BorderBrush" Value="#2563EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1D4ED8"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1E40AF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FFFFFF" Offset="0.00"/>
                <GradientStop Color="#F3F9FF" Offset="0.35"/>
                <GradientStop Color="#DBEAFE" Offset="0.76"/>
                <GradientStop Color="#EFF6FF" Offset="1.00"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Ellipse Width="420" Height="420" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-160,-180,0,0" Opacity="0.48">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#60A5FA" Offset="0"/>
                    <GradientStop Color="#BFDBFE" Offset="0.55"/>
                    <GradientStop Color="#00FFFFFF" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
            <Ellipse.Effect>
                <BlurEffect Radius="42"/>
            </Ellipse.Effect>
        </Ellipse>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <ui:TitleBar Grid.Row="0" Title="Hồ sơ &amp; Cài đặt" Foreground="#0F172A" Background="Transparent">
                <ui:TitleBar.Icon>
                    <ui:SymbolIcon Symbol="Person24" Foreground="#2563EB"/>
                </ui:TitleBar.Icon>
            </ui:TitleBar>

            <Grid Grid.Row="1" Margin="28,18,28,26">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Hồ sơ cá nhân" Style="{StaticResource PageTitleStyle}"/>
                        <TextBlock Text="Quản lý thông tin tài khoản, mã chia sẻ, mật khẩu và cài đặt ứng dụng." Style="{StaticResource PageSubTitleStyle}" Margin="0,6,0,0"/>
                    </StackPanel>

                    <Border Grid.Column="1" CornerRadius="18" Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1" Padding="14,9" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Shield24" Foreground="#2563EB" FontSize="18" Margin="0,0,7,0"/>
                            <TextBlock Text="E2EE Ready" Foreground="#1E3A8A" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource GlassCardStyle}" Margin="0,0,18,0">
                        <StackPanel>
                            <Border Width="96" Height="96" CornerRadius="32" Background="#2563EB" HorizontalAlignment="Left" Margin="0,0,0,18">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="28" ShadowDepth="8" Opacity="0.22" Color="#2563EB"/>
                                </Border.Effect>
                                <ui:SymbolIcon Symbol="Person24" FontSize="48" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <TextBlock Text="{Binding User.DisplayName}" Foreground="#0F172A" FontSize="24" FontWeight="Bold" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding User.Email}" Foreground="#64748B" FontSize="13" TextWrapping="Wrap" Margin="0,6,0,18"/>

                            <Border CornerRadius="18" Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1" Padding="14" Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="Mã chia sẻ" Foreground="#64748B" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding User.ShareCode}" Foreground="#2563EB" FontFamily="Consolas" FontSize="19" FontWeight="Bold" TextWrapping="Wrap" Margin="0,6,0,12"/>

                                    <Button Style="{StaticResource PrimaryButtonStyle}" Command="{Binding CopyIdCommand}" HorizontalAlignment="Stretch">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="Copy24" Foreground="White" FontSize="18" Margin="0,0,7,0"/>
                                            <TextBlock Text="Copy mã" Foreground="White" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <TextBlock Text="{Binding CopyMessage}" Foreground="#059669" FontWeight="SemiBold" FontSize="12" HorizontalAlignment="Center" Margin="0,6,0,0" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SmallInfoCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="42" Height="42" CornerRadius="15" Background="#FEF3C7" Margin="0,0,12,0">
                                        <ui:SymbolIcon Symbol="Star24" Foreground="#D97706" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Gói hiện tại" Foreground="#64748B" FontSize="12"/>
                                        <TextBlock Text="{Binding User.Plan}" Foreground="#0F172A" FontSize="16" FontWeight="Bold" Margin="0,3,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource GlassCardStyle}" Margin="0">
                        <ui:TabView>
                            <ui:TabViewItem Header="Hồ sơ">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel Margin="4,10,8,6">

                                        <TextBlock Text="{Binding GoogleWarningMessage}" Foreground="#D97706" FontWeight="SemiBold" Margin="0,0,0,10" 
                                                   Visibility="{Binding GoogleWarningMessage, Converter={StaticResource StringToVisibility}}"/>

                                        <Border Style="{StaticResource SmallInfoCardStyle}" Padding="20">
                                            <StackPanel>
                                                <TextBlock Text="Thông tin tài khoản" Style="{StaticResource SectionTitleStyle}"/>

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="150"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="14"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="14"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="16"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Username" Style="{StaticResource FieldLabelStyle}" VerticalAlignment="Center"/>
                                                    <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource RoundedInputBorderStyle}" Margin="0">
                                                        <ui:TextBox Text="{Binding User.UserName, UpdateSourceTrigger=PropertyChanged}" Icon="{ui:SymbolIcon Person24}" Style="{StaticResource ModernTextBoxStyle}"/>
                                                    </Border>

                                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Tên hiển thị" Style="{StaticResource FieldLabelStyle}" VerticalAlignment="Center"/>
                                                    <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource RoundedInputBorderStyle}" Margin="0">
                                                        <ui:TextBox Text="{Binding User.DisplayName, UpdateSourceTrigger=PropertyChanged}" Icon="{ui:SymbolIcon Person24}" Style="{StaticResource ModernTextBoxStyle}"/>
                                                    </Border>

                                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Email" Style="{StaticResource FieldLabelStyle}" VerticalAlignment="Center"/>
                                                    <Border Grid.Row="4" Grid.Column="1" Style="{StaticResource RoundedInputBorderStyle}" Margin="0">
                                                        <ui:TextBox Text="{Binding User.Email, UpdateSourceTrigger=PropertyChanged}" Icon="{ui:SymbolIcon Mail24}" Style="{StaticResource ModernTextBoxStyle}" IsEnabled="{Binding IsEmailEditable}"/>
                                                    </Border>

                                                    <Button Grid.Row="6" Grid.Column="1" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding UpdateProfileCommand}" HorizontalAlignment="Right">
                                                        <Grid>
                                                            <StackPanel Orientation="Horizontal" Visibility="{Binding IsUpdatingProfile, Converter={StaticResource InverseBoolToVisibility}}">
                                                                <ui:SymbolIcon Symbol="Save24" Foreground="White" FontSize="18" Margin="0,0,7,0"/>
                                                                <TextBlock Text="Lưu thông tin" Foreground="White" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                            <ui:ProgressRing IsIndeterminate="True" Width="20" Height="20" Foreground="White" Visibility="{Binding IsUpdatingProfile, Converter={StaticResource BoolToVisibility}}"/>
                                                        </Grid>
                                                    </Button>
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <Border Style="{StaticResource SmallInfoCardStyle}" Padding="20" Margin="0" Visibility="{Binding IsPasswordSectionVisible, Converter={StaticResource BoolToVisibility}}">
                                            <StackPanel>
                                                <TextBlock Text="Đổi mật khẩu" Style="{StaticResource SectionTitleStyle}"/>
                                                <TextBlock Text="Nên dùng mật khẩu mạnh để bảo vệ tài khoản và dữ liệu cá nhân." Style="{StaticResource MutedTextStyle}" Margin="0,0,0,16"/>

                                                <TextBlock Text="Mật khẩu hiện tại" Style="{StaticResource FieldLabelStyle}"/>
                                                <Border Style="{StaticResource RoundedInputBorderStyle}">
                                                    <ui:PasswordBox Icon="{ui:SymbolIcon LockClosed24}" Style="{StaticResource ModernPasswordBoxStyle}" helpers:PasswordBoxHelper.BoundPassword="{Binding OldPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                </Border>

                                                <TextBlock Text="Mật khẩu mới" Style="{StaticResource FieldLabelStyle}"/>
                                                <Border Style="{StaticResource RoundedInputBorderStyle}">
                                                    <ui:PasswordBox Icon="{ui:SymbolIcon Password24}" Style="{StaticResource ModernPasswordBoxStyle}" helpers:PasswordBoxHelper.BoundPassword="{Binding NewPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                </Border>

                                                <TextBlock Text="Nhập lại mật khẩu mới" Style="{StaticResource FieldLabelStyle}"/>
                                                <Border Style="{StaticResource RoundedInputBorderStyle}" Margin="0,0,0,18">
                                                    <ui:PasswordBox Icon="{ui:SymbolIcon LockShield24}" Style="{StaticResource ModernPasswordBoxStyle}" helpers:PasswordBoxHelper.BoundPassword="{Binding ConfirmNewPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                </Border>

                                                <Button Style="{StaticResource PrimaryButtonStyle}" Command="{Binding ChangePasswordCommand}" HorizontalAlignment="Right">
                                                    <Grid>
                                                        <StackPanel Orientation="Horizontal" Visibility="{Binding IsChangingPassword, Converter={StaticResource InverseBoolToVisibility}}">
                                                            <ui:SymbolIcon Symbol="LockClosed24" Foreground="White" FontSize="18" Margin="0,0,7,0"/>
                                                            <TextBlock Text="Cập nhật mật khẩu" Foreground="White" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        <ui:ProgressRing IsIndeterminate="True" Width="20" Height="20" Foreground="White" Visibility="{Binding IsChangingPassword, Converter={StaticResource BoolToVisibility}}"/>
                                                    </Grid>
                                                </Button>
                                            </StackPanel>
                                        </Border>

                                        <TextBlock Text="{Binding StatusMessage}" FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,10,0,0" HorizontalAlignment="Center"
                                                   Visibility="{Binding HasStatus, Converter={StaticResource BoolToVisibility}}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#059669"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsStatusError}" Value="True">
                                                            <Setter Property="Foreground" Value="#EF4444"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                    </StackPanel>
                                </ScrollViewer>
                            </ui:TabViewItem>

                            <ui:TabViewItem Header="Cài đặt hệ thống">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel Margin="4,10,8,6">

                                        <Border Style="{StaticResource SmallInfoCardStyle}" Padding="20">
                                            <StackPanel>
                                                <TextBlock Text="Giao diện" Style="{StaticResource SectionTitleStyle}"/>
                                                <TextBlock Text="Đồng bộ lựa chọn giao diện để trải nghiệm nhất quán trên thiết bị." Style="{StaticResource MutedTextStyle}" Margin="0,0,0,16"/>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <Border Grid.Column="0" CornerRadius="18" Background="#FFFFFF" BorderBrush="#D8E6FF" BorderThickness="1" Padding="14" Margin="0,0,10,0">
                                                        <RadioButton GroupName="Theme" Content="Sáng" FontWeight="SemiBold" 
                                                                     Command="{Binding ChangeThemeCommand}" CommandParameter="Light" IsChecked="True"/>
                                                    </Border>

                                                    <Border Grid.Column="1" CornerRadius="18" Background="#FFFFFF" BorderBrush="#D8E6FF" BorderThickness="1" Padding="14" Margin="0,0,10,0">
                                                        <RadioButton GroupName="Theme" Content="Tối" FontWeight="SemiBold" 
                                                                     Command="{Binding ChangeThemeCommand}" CommandParameter="Dark"/>
                                                    </Border>

                                                    <Border Grid.Column="2" CornerRadius="18" Background="#FFFFFF" BorderBrush="#D8E6FF" BorderThickness="1" Padding="14">
                                                        <RadioButton GroupName="Theme" Content="Hệ thống" FontWeight="SemiBold" 
                                                                     Command="{Binding ChangeThemeCommand}" CommandParameter="System"/>
                                                    </Border>
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <Border Style="{StaticResource SmallInfoCardStyle}" Padding="20">
                                            <StackPanel>
                                                <TextBlock Text="Ngôn ngữ" Style="{StaticResource SectionTitleStyle}"/>
                                                <TextBlock Text="Chọn ngôn ngữ hiển thị trên ứng dụng." Style="{StaticResource MutedTextStyle}" Margin="0,0,0,12"/>
                                                <ComboBox ItemsSource="{Binding Languages}" SelectedItem="{Binding SelectedLanguage}" 
                                                          Width="240" Height="42" HorizontalAlignment="Left" FontSize="14" Foreground="#0F172A"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Style="{StaticResource SmallInfoCardStyle}" Padding="20">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Width="52" Height="52" CornerRadius="18" Background="#EFF6FF" Margin="0,0,16,0">
                                                    <ui:SymbolIcon Symbol="Alert24" Foreground="#2563EB" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="Thông báo ứng dụng" Foreground="#0F172A" FontSize="17" FontWeight="Bold"/>
                                                    <TextBlock Text="Nhận thông báo khi có file mới, OCR hoàn tất, lời mời nhóm." Style="{StaticResource MutedTextStyle}" Margin="0,4,0,0"/>
                                                </StackPanel>
                                                <ui:ToggleSwitch Grid.Column="2" IsChecked="{Binding NotificationsEnabled}" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>

                                        <Border Style="{StaticResource SmallInfoCardStyle}" Padding="20" Margin="0">
                                            <StackPanel>
                                                <TextBlock Text="Thông tin ứng dụng" Style="{StaticResource SectionTitleStyle}"/>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="160"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="12"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="12"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Tên ứng dụng" Style="{StaticResource FieldLabelStyle}"/>
                                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Trợ Lý Số Cá Nhân" Style="{StaticResource FieldValueStyle}"/>
                                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Phiên bản" Style="{StaticResource FieldLabelStyle}"/>
                                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="1.0.0" Style="{StaticResource FieldValueStyle}"/>
                                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Build" Style="{StaticResource FieldLabelStyle}"/>
                                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="2026.06.04" Style="{StaticResource FieldValueStyle}"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                    </StackPanel>
                                </ScrollViewer>
                            </ui:TabViewItem>

                        </ui:TabView>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>