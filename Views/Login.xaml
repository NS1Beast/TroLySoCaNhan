<ui:FluentWindow x:Class="TroLySoCaNhan.Views.Login"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:local="clr-namespace:TroLySoCaNhan.Views"
                 xmlns:vm="clr-namespace:TroLySoCaNhan.ViewModels"
                 xmlns:helpers="clr-namespace:TroLySoCaNhan.MVVM.Converters"
                 mc:Ignorable="d"
                 Title="Đăng nhập - Trợ lý số cá nhân"
                 Height="650" Width="1000"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True"
                 WindowStartupLocation="CenterScreen">

    <ui:FluentWindow.DataContext>
        <vm:LoginViewModel />
    </ui:FluentWindow.DataContext>

    <!-- Chỉ giữ hiệu ứng Parallax ở code-behind (không phải business logic) -->
    <Grid MouseMove="Grid_MouseMove">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0f172a" Offset="0.0" />
                <GradientStop Color="#1e293b" Offset="1.0" />
            </LinearGradientBrush>
        </Grid.Background>

        <ui:TitleBar Title="Trợ Lý Số Cá Nhân" VerticalAlignment="Top" Foreground="White">
            <ui:TitleBar.Icon>
                <ui:SymbolIcon Symbol="Bot24" Foreground="#3b82f6" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <Grid Margin="0,32,0,0">
            <Grid Width="860" HorizontalAlignment="Center" VerticalAlignment="Center">

                <!-- PHẦN BRANDING (Bên phải) -->
                <StackPanel x:Name="pnlBranding" HorizontalAlignment="Right" VerticalAlignment="Center" Width="380">
                    <StackPanel.RenderTransform>
                        <TranslateTransform x:Name="transBranding" X="0"/>
                    </StackPanel.RenderTransform>
                    <ui:SymbolIcon Symbol="Bot24" FontSize="90" Foreground="#3b82f6" Margin="0,0,0,20"/>
                    <TextBlock Text="Trợ Lý Số Cá Nhân" FontSize="42" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" />
                    <TextBlock Text="Không gian quản lý tài liệu, tài khoản và giao tiếp an toàn, thông minh." FontSize="16" Foreground="#94a3b8" Margin="0,15,0,0" TextWrapping="Wrap" TextAlignment="Center" />
                </StackPanel>

                <!-- PHẦN FORM CARD (Bên trái) -->
                <Border x:Name="cardForm" HorizontalAlignment="Left" VerticalAlignment="Center" Width="410" Height="580"
                        CornerRadius="16" Background="#1e293b"
                        BorderBrush="#334155" BorderThickness="1" ClipToBounds="True">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.5" Color="Black"/>
                    </Border.Effect>
                    <Border.RenderTransform>
                        <TranslateTransform x:Name="transCard" X="0"/>
                    </Border.RenderTransform>

                    <Grid>
                        <!-- 1. PANEL ĐĂNG NHẬP -->
                        <StackPanel x:Name="pnlLogin" Background="Transparent" Margin="40,35">
                            <StackPanel.RenderTransform>
                                <TranslateTransform x:Name="transLogin" X="0"/>
                            </StackPanel.RenderTransform>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActivePanel}" Value="Register">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ActivePanel}" Value="Forgot">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <TextBlock Text="Chào mừng trở lại!" FontSize="28" FontWeight="Bold" Margin="0,0,0,25" Foreground="White" HorizontalAlignment="Center"/>

                            <TextBlock Text="Tên đăng nhập / Email" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="#94a3b8"/>
                            <ui:TextBox PlaceholderText="Nhập email của bạn"
                                        Icon="{ui:SymbolIcon Person24}"
                                        Margin="0,0,0,15" Height="40" Foreground="White"
                                        Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Text="Mật khẩu" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="#94a3b8"/>
                            <ui:PasswordBox PlaceholderText="••••••••"
                                            Icon="{ui:SymbolIcon Password24}"
                                            Margin="0,0,0,10" Height="40" Foreground="White"
                                            PasswordChanged="txtPassword_PasswordChanged"/>

                            <!-- Dòng báo lỗi -->
                            <TextBlock Text="{Binding ErrorMessage}" Foreground="#f87171"
                                       FontSize="12" Margin="0,0,0,8"
                                       Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}" />

                            <Grid Margin="0,0,0,20">
                                <CheckBox Content="Nhớ tài khoản" Foreground="#94a3b8"
                                          IsChecked="{Binding RememberMe}"
                                          HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <Hyperlink TextDecorations="None" Foreground="#3b82f6"
                                               Command="{Binding ShowForgotCommand}">Quên mật khẩu?</Hyperlink>
                                </TextBlock>
                            </Grid>

                            <!-- Nút Đăng nhập -->
                            <ui:Button Appearance="Primary" Background="#3b82f6" BorderBrush="#3b82f6"
                                       HorizontalAlignment="Stretch" Margin="0,0,0,15" Height="45"
                                       Command="{Binding LoginCommand}">
                                <Grid>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                                Visibility="{Binding IsLoggingIn, Converter={StaticResource InverseBoolToVisibility}}">
                                        <ui:SymbolIcon Symbol="ArrowRight24" Margin="0,0,8,0" FontSize="18" Foreground="White"/>
                                        <TextBlock Text="Đăng nhập" FontSize="15" FontWeight="Bold" Foreground="White"/>
                                    </StackPanel>
                                    <ui:ProgressRing IsIndeterminate="True" Width="20" Height="20" Foreground="White"
                                                     Visibility="{Binding IsLoggingIn, Converter={StaticResource BoolToVisibility}}"/>
                                </Grid>
                            </ui:Button>

                            <!-- Đường chia cắt HOẶC -->
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Separator Grid.Column="0" VerticalAlignment="Center" Margin="0,0,10,0" Background="#334155"/>
                                <TextBlock Grid.Column="1" Text="HOẶC" Foreground="#64748b" FontSize="12"/>
                                <Separator Grid.Column="2" VerticalAlignment="Center" Margin="10,0,0,0" Background="#334155"/>
                            </Grid>

                            <!-- Nút OpenID thay cho tài khoản khách -->
                            <ui:Button Appearance="Secondary" HorizontalAlignment="Stretch" Margin="0,0,0,20" Height="45"
                                       Background="#0f172a" BorderBrush="#334155">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="ShieldKeyhole24" Foreground="White" Margin="0,0,8,0"/>
                                    <TextBlock Text="Đăng nhập qua OpenID / SSO" Foreground="White" FontWeight="SemiBold"/>
                                </StackPanel>
                            </ui:Button>

                            <!-- Link Đăng ký -->
                            <TextBlock HorizontalAlignment="Center">
                                <Run Text="Chưa có tài khoản? " Foreground="#94a3b8"/>
                                <Hyperlink TextDecorations="None" Foreground="#3b82f6" FontWeight="SemiBold"
                                           Command="{Binding ShowRegisterCommand}">Tạo tài khoản</Hyperlink>
                            </TextBlock>
                        </StackPanel>

                        <!-- 2. PANEL ĐĂNG KÝ -->
                        <StackPanel x:Name="pnlRegister" Background="Transparent" Margin="40,30"
                                    Visibility="{Binding ActivePanel, Converter={StaticResource StringToVisibility}, ConverterParameter=Register}">
                            <StackPanel.RenderTransform>
                                <TranslateTransform x:Name="transRegister" X="420"/>
                            </StackPanel.RenderTransform>
                            <TextBlock Text="Tạo tài khoản mới" FontSize="26" FontWeight="Bold" Margin="0,0,0,20" Foreground="White" HorizontalAlignment="Center"/>
                            <ui:TextBox PlaceholderText="Họ và tên" Icon="{ui:SymbolIcon Person24}" Margin="0,0,0,15" Height="38" Foreground="White"
                                        Text="{Binding RegFullName, UpdateSourceTrigger=PropertyChanged}" />
                            <ui:TextBox PlaceholderText="Email" Icon="{ui:SymbolIcon Mail24}" Margin="0,0,0,15" Height="38" Foreground="White"
                                        Text="{Binding RegEmail, UpdateSourceTrigger=PropertyChanged}" />
                            <ui:PasswordBox PlaceholderText="Mật khẩu" Icon="{ui:SymbolIcon LockClosed24}" Margin="0,0,0,15" Height="38" Foreground="White"
                                            helpers:PasswordBoxHelper.BoundPassword="{Binding RegPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <ui:PasswordBox PlaceholderText="Nhập lại mật khẩu" Icon="{ui:SymbolIcon LockClosed24}" Margin="0,0,0,15" Height="38" Foreground="White"
                                            helpers:PasswordBoxHelper.BoundPassword="{Binding RegConfirmPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <ui:Button Appearance="Primary" Background="#3b82f6" BorderBrush="#3b82f6"
                                       HorizontalAlignment="Stretch" Margin="0,15,0,20" Height="45"
                                       Command="{Binding RegisterCommand}">
                                <Grid>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                                Visibility="{Binding IsRegistering, Converter={StaticResource InverseBoolToVisibility}}">
                                        <ui:SymbolIcon Symbol="Add24" Margin="0,0,8,0" FontSize="18" Foreground="White"/>
                                        <TextBlock Text="Đăng ký tài khoản" FontSize="15" FontWeight="Bold" Foreground="White"/>
                                    </StackPanel>
                                    <ui:ProgressRing IsIndeterminate="True" Width="20" Height="20" Foreground="White"
                                                     Visibility="{Binding IsRegistering, Converter={StaticResource BoolToVisibility}}"/>
                                </Grid>
                            </ui:Button>
                            <TextBlock HorizontalAlignment="Center">
                                <Hyperlink TextDecorations="None" Foreground="#3b82f6" FontWeight="SemiBold"
                                           Command="{Binding ShowLoginCommand}">Quay lại đăng nhập</Hyperlink>
                            </TextBlock>
                        </StackPanel>

                        <!-- 3. PANEL QUÊN MẬT KHẨU -->
                        <StackPanel x:Name="pnlForgotPassword" Background="Transparent" Margin="40,30"
                                    Visibility="{Binding ActivePanel, Converter={StaticResource StringToVisibility}, ConverterParameter=Forgot}">
                            <StackPanel.RenderTransform>
                                <TranslateTransform x:Name="transForgot" X="420"/>
                            </StackPanel.RenderTransform>
                            <TextBlock Text="Khôi phục mật khẩu" FontSize="24" FontWeight="Bold" Margin="0,0,0,15" Foreground="White" HorizontalAlignment="Center"/>
                            <ui:TextBox PlaceholderText="Email đăng ký" Icon="{ui:SymbolIcon Mail24}" Margin="0,0,0,15" Height="38" Foreground="White"
                                        Text="{Binding ForgotEmail, UpdateSourceTrigger=PropertyChanged}" />

                            <ui:Button Appearance="Primary" Background="#3b82f6" BorderBrush="#3b82f6"
                                       HorizontalAlignment="Stretch" Margin="0,15,0,20" Height="45"
                                       Command="{Binding ForgotPasswordCommand}">
                                <Grid>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                                Visibility="{Binding IsSendingForgot, Converter={StaticResource InverseBoolToVisibility}}">
                                        <ui:SymbolIcon Symbol="Send24" Margin="0,0,8,0" FontSize="18" Foreground="White"/>
                                        <TextBlock Text="Gửi mã khôi phục" FontSize="15" FontWeight="Bold" Foreground="White"/>
                                    </StackPanel>
                                    <ui:ProgressRing IsIndeterminate="True" Width="20" Height="20" Foreground="White"
                                                     Visibility="{Binding IsSendingForgot, Converter={StaticResource BoolToVisibility}}"/>
                                </Grid>
                            </ui:Button>
                            <TextBlock HorizontalAlignment="Center">
                                <Hyperlink TextDecorations="None" Foreground="#3b82f6" FontWeight="SemiBold"
                                           Command="{Binding ShowLoginCommand}">Quay lại</Hyperlink>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>
