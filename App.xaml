<Application x:Class="TroLySoCaNhan.App"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
               xmlns:conv="clr-namespace:TroLySoCaNhan.MVVM.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ControlsDictionary />
                <ui:ThemesDictionary />
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters toàn cục cho DataBinding MVVM -->
            <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
            <conv:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisibility" />
            <conv:StringToVisibilityConverter x:Key="StringToVisibility" />
            <conv:StringEqualsConverter x:Key="StringEquals" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
